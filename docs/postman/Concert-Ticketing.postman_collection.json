{
  "info": {
    "name": "Concert Ticketing API",
    "description": "Local API collection — mock payment flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "bookingId", "value": "1" },
    { "key": "concertId", "value": "1" },
    { "key": "ticketCategoryId", "value": "1" },
    { "key": "idempotencyKey", "value": "{{$guid}}" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@demo.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@demo.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Customer",
      "item": [
        {
          "name": "List Concerts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/concerts"
          }
        },
        {
          "name": "Concert Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/concerts/{{concertId}}"
          }
        },
        {
          "name": "Validate Voucher",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/vouchers/validate/FLASH10"
          }
        },
        {
          "name": "Create Booking (PENDING)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('bookingId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"concertId\": {{concertId}},\n  \"idempotencyKey\": \"{{idempotencyKey}}\",\n  \"voucherCode\": \"FLASH10\",\n  \"items\": [\n    { \"ticketCategoryId\": {{ticketCategoryId}}, \"quantity\": 1 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "Mock Pay Booking",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/bookings/{{bookingId}}/pay"
          }
        },
        {
          "name": "My Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/bookings/me"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/bookings"
          }
        },
        {
          "name": "List Concerts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/concerts"
          }
        },
        {
          "name": "List Vouchers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/vouchers"
          }
        }
      ]
    }
  ]
}
